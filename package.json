{
  "name": "crawlix",
  "version": "0.1.2",
  "description": "AI testers that think like users. Your users will break it anyway. Crawlix finds it first.",
  "main": "./dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "testing",
    "qa",
    "automation",
    "playwright",
    "agents",
    "llm"
  ],
  "author": "Muhammad Taqi",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "bin": {
    "crawlix": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@inquirer/prompts": "^8.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "openai": "^6.39.0",
    "ora": "^9.4.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}